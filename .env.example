# 环境变量配置文件
# 复制此文件为 .env 并填入真实的API密钥

# AI API配置
AI_API_ENDPOINT=https://api.qnaigc.com/v1/chat/completions
AI_API_KEY=your-api-key-here
AI_MODEL=minimax/minimax-m2.1

# 游戏配置
GAME_DEBUG_MODE=true
GAME_LOG_LEVEL=info

# NPC配置
NPC_DECISION_INTERVAL=30000
NPC_MAX_MEMORY_SIZE=2000
NPC_COMMUNICATION_RANGE=100